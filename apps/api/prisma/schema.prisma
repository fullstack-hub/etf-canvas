generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Etf {
  code                String   @id @db.VarChar(10)
  name                String   @db.VarChar(100)
  categories          String[] @default([])
  etfTabCode          Int?     @map("etf_tab_code")
  benchmark           String?  @db.VarChar(100)
  issuer              String?  @db.VarChar(50)
  listedDate          DateTime? @map("listed_date") @db.Date
  price               Int?
  changeRate          Decimal? @map("change_rate") @db.Decimal(8, 4)
  nav                 Decimal? @db.Decimal(12, 2)
  oneMonthEarnRate    Decimal? @map("one_month_earn_rate") @db.Decimal(8, 4)
  threeMonthEarnRate  Decimal? @map("three_month_earn_rate") @db.Decimal(8, 4)
  sixMonthEarnRate    Decimal? @map("six_month_earn_rate") @db.Decimal(8, 4)
  oneYearEarnRate     Decimal? @map("one_year_earn_rate") @db.Decimal(8, 4)
  volume              BigInt?
  aum                 BigInt?
  expenseRatio        Decimal? @map("expense_ratio") @db.Decimal(5, 4)
  dividendYield       Decimal? @map("dividend_yield") @db.Decimal(6, 2)
  updatedAt           DateTime @default(now()) @map("updated_at") @updatedAt

  holdings    EtfHolding[]
  dailyPrices EtfDailyPrice[]
  returns     EtfReturn[]
  dividends   EtfDividend[]

  @@index([benchmark])
  @@index([aum(sort: Desc)])
  @@index([name])
  @@map("etf")
}

model EtfHolding {
  id        Int      @id @default(autoincrement())
  etfCode   String   @map("etf_code") @db.VarChar(10)
  stockCode String?  @map("stock_code") @db.VarChar(10)
  stockName String?  @map("stock_name") @db.VarChar(100)
  weight    Decimal? @db.Decimal(6, 3)
  shares    BigInt?
  updatedAt DateTime @default(now()) @map("updated_at") @updatedAt

  etf Etf @relation(fields: [etfCode], references: [code])

  @@index([etfCode])
  @@map("etf_holding")
}

model EtfDailyPrice {
  etfCode String   @map("etf_code") @db.VarChar(10)
  date    DateTime @db.Date
  close   Int
  open    Int
  high    Int
  low     Int
  volume  BigInt
  nav     Decimal? @db.Decimal(12, 2)

  etf Etf @relation(fields: [etfCode], references: [code])

  @@id([etfCode, date])
  @@map("etf_daily_price")
}

model Portfolio {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id")
  name        String   @db.VarChar(100)
  items       Json
  snapshot    Json?
  returnRate  Decimal? @map("return_rate") @db.Decimal(8, 2)
  mdd         Decimal? @db.Decimal(8, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at") @updatedAt

  @@index([userId])
  @@map("portfolio")
}

model EtfDividend {
  etfCode  String   @map("etf_code") @db.VarChar(10)
  date     DateTime @db.Date
  payDate  DateTime @map("pay_date") @db.Date
  amount   Int
  rate     Decimal  @db.Decimal(8, 5)

  etf Etf @relation(fields: [etfCode], references: [code])

  @@id([etfCode, date])
  @@map("etf_dividend")
}

model EtfReturn {
  etfCode    String   @map("etf_code") @db.VarChar(10)
  period     String   @db.VarChar(10)
  returnRate Decimal  @map("return_rate") @db.Decimal(8, 4)
  updatedAt  DateTime @default(now()) @map("updated_at") @updatedAt

  etf Etf @relation(fields: [etfCode], references: [code])

  @@id([etfCode, period])
  @@map("etf_return")
}
